CLAUDE_CODE_USE_FOUNDRY=1

#ANTHROPIC_FOUNDRY_RESOURCE=<ai-foundry-resource>
ANTHROPIC_FOUNDRY_BASE_URL=https://.openai.azure.com/anthropic

ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-5

ANTHROPIC_AZURE_AD_SCOPE=https://cognitiveservices.azure.com/.default


GEMINI_API_KEY=

# Required
CLAUDE_CODE_ENABLE_TELEMETRY=1
# Choose exporters
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
# Point at your local collector
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Faster intervals for initial testing (defaults: 60s metrics, 5s logs)
OTEL_METRIC_EXPORT_INTERVAL=60000
OTEL_LOGS_EXPORT_INTERVAL=10000